{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Values Atlas Data Point",
  "description": "Schema for entries in data/atlas.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "region", "thread", "lat", "lng", "epoch", "values", "drivers", "status", "evidence", "confidence", "contested", "note"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique kebab-case identifier",
        "pattern": "^[a-z0-9-]+$"
      },
      "region": {
        "type": "string",
        "description": "Human-readable region name"
      },
      "thread": {
        "type": "string",
        "description": "Civilization thread for filtering",
        "enum": ["arabia", "china", "india", "europe", "steppe", "africa", "americas", "none"]
      },
      "lat": {
        "type": "number",
        "minimum": -90,
        "maximum": 90
      },
      "lng": {
        "type": "number",
        "minimum": -180,
        "maximum": 180
      },
      "epoch": {
        "type": "string",
        "enum": ["hunter", "early-agr", "bronze", "iron", "axial", "imperial", "medieval", "early-mod", "industrial", "modern", "now"]
      },
      "values": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["valueId", "intensity", "role"],
          "additionalProperties": false,
          "properties": {
            "valueId": {
              "type": "string",
              "enum": ["generosity", "hospitality", "solidarity", "aggression", "honor", "piety", "curiosity", "individualism", "collectivism", "egalitarianism", "order", "hierarchy"]
            },
            "intensity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "role": {
              "type": "string",
              "enum": ["primary", "coupled", "counter"]
            }
          }
        }
      },
      "drivers": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["resource_scarcity", "pathogen_load", "weak_institutions", "open_frontier", "kinship_intensity", "resource_competition", "hydraulic_coordination", "institutional_scale", "trade_networks", "colonial_pressure", "secularism_threat", "technological_surplus", "metallurgy", "maritime_expansion", "nomadic_mobility", "literacy", "monumental_religion", "military_revolution", "industrialization"]
        }
      },
      "status": {
        "type": "string",
        "enum": ["adaptive", "residual", "reactive", "reactivated"]
      },
      "evidence": {
        "type": "string",
        "enum": ["ethnographic", "textual", "archaeological", "inferred", "speculative"]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "contested": {
        "type": "boolean"
      },
      "contestNote": {
        "type": "string"
      },
      "note": {
        "type": "string"
      },
      "altReading": {
        "type": "string"
      },
      "cost": {
        "type": "string"
      },
      "successor": {
        "type": "string"
      },
      "artifact": {
        "type": "string"
      },
      "sources": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "schemaVersion": {
        "type": "integer",
        "minimum": 1,
        "description": "Data model version. Omitted/1 = legacy flat fields only; 2 = additive aspects layer present."
      },
      "aspects": {
        "type": "array",
        "description": "Generalized thematic dimensions. Additive; the values-synthesis aspect mirrors the legacy note/altReading/cost/sources content.",
        "items": {
          "type": "object",
          "required": ["type", "readings"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["values-synthesis", "gender", "myth", "religion", "commerce", "law", "governance", "daily-life", "architecture", "dress", "script", "art"]
            },
            "readings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["text"],
                "additionalProperties": false,
                "properties": {
                  "text": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "contested": { "type": "boolean" },
                  "contestNote": { "type": "string" },
                  "sources": { "type": "array", "items": { "type": "string" } },
                  "citationKeys": { "type": "array", "items": { "type": "string" } },
                  "translations": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "license": { "type": "string", "description": "SPDX or human-readable license of the source this reading draws on (provenance)." },
                  "sourceDataset": { "type": "string", "description": "Identifier of the originating dataset/source for this reading (provenance)." }
                }
              }
            }
          }
        }
      },
      "media": {
        "type": "array",
        "description": "Optional associated media (images or other resources).",
        "items": {
          "type": "object",
          "required": ["url", "type"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string" },
            "type": { "type": "string", "enum": ["image", "other"] },
            "caption": { "type": "string" },
            "attribution": { "type": "string" },
            "license": { "type": "string" }
          }
        }
      },
      "bibliography": {
        "type": "array",
        "description": "Structured bibliography; reading.citationKeys reference entry.key.",
        "items": {
          "type": "object",
          "required": ["key", "title"],
          "additionalProperties": false,
          "properties": {
            "key": { "type": "string" },
            "title": { "type": "string" },
            "authors": { "type": "array", "items": { "type": "string" } },
            "year": { "type": "integer" },
            "venue": { "type": "string" },
            "doi": { "type": "string" },
            "isbn": { "type": "string" },
            "url": { "type": "string" },
            "license": { "type": "string", "description": "SPDX or human-readable license of the cited source (provenance)." },
            "sourceDataset": { "type": "string", "description": "Identifier of the originating dataset/source for this citation (provenance)." }
          }
        }
      }
    }
  }
}
